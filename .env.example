# ── Base de datos ──────────────────────────────────────────────
# Puerto 5434 (mapeo del contenedor) para no chocar con un PostgreSQL local.
DATABASE_URL="postgresql://poscoffe:poscoffe@localhost:5434/poscoffe?schema=public"

# ── Redis (caché / colas / realtime) ───────────────────────────
REDIS_URL="redis://localhost:6380"

# ── Auth ───────────────────────────────────────────────────────
JWT_ACCESS_SECRET="cambia-esto-en-produccion-access"
JWT_REFRESH_SECRET="cambia-esto-en-produccion-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# ── Servidor ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# ── Frontend (apps/pos) ────────────────────────────────────────
VITE_API_URL="http://localhost:3000/api/v1"
VITE_WS_URL="http://localhost:3000"
