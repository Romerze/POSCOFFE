// POSCOFFE — Esquema de datos canónico.
// Refleja docs/07-modelo-datos.md. Multi-local desde el día 1 (local_id),
// movimientos de stock append-only por deltas para sync offline.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Identidad y acceso ───────────────────────────

model Local {
  id        String   @id @default(uuid())
  nombre    String
  direccion String?
  timezone  String   @default("America/Lima")
  moneda    String   @default("PEN")
  config    Json     @default("{}")
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now()) @map("creado_en")

  usuarios     Usuario[]
  categorias   Categoria[]
  productos    Producto[]
  inventario   Inventario[]
  pedidos      Pedido[]
  promociones  Promocion[]
  reposiciones Reposicion[]
  mermas       Merma[]
  alertasStock AlertaStock[]
  turnos       Turno[]
  cajas        Caja[]
  movStock     MovimientoStock[]

  @@map("local")
}

model Rol {
  id       String  @id @default(uuid())
  nombre   String  @unique
  permisos Json    @default("[]")
  usuarios Usuario[]

  @@map("rol")
}

model Usuario {
  id           String   @id @default(uuid())
  localId      String?  @map("local_id") // null = acceso multi-local (p.ej. dueño)
  nombre       String
  email        String   @unique
  passwordHash String   @map("password_hash")
  pinHash      String?  @map("pin_hash")
  rolId        String   @map("rol_id")
  activo       Boolean  @default(true)
  creadoEn     DateTime @default(now()) @map("creado_en")

  local        Local?            @relation(fields: [localId], references: [id])
  rol          Rol               @relation(fields: [rolId], references: [id])
  pedidos      Pedido[]
  turnos       Turno[]
  reposiciones Reposicion[]
  mermas       Merma[]

  @@index([localId])
  @@map("usuario")
}

// ─────────────────────────────── Catálogo ─────────────────────────────────

model Categoria {
  id       String     @id @default(uuid())
  localId  String     @map("local_id")
  nombre   String
  orden    Int        @default(0)
  icono    String?
  local    Local      @relation(fields: [localId], references: [id])
  productos Producto[]

  @@index([localId])
  @@map("categoria")
}

model Producto {
  id          String   @id @default(uuid())
  localId     String   @map("local_id")
  categoriaId String   @map("categoria_id")
  nombre      String
  descripcion String?
  imagen      String?
  esCombo     Boolean  @default(false) @map("es_combo")
  activo      Boolean  @default(true)

  local      Local                     @relation(fields: [localId], references: [id])
  categoria  Categoria                 @relation(fields: [categoriaId], references: [id])
  variantes  Variante[]
  modGrupos  ProductoModificadorGrupo[]

  @@index([localId])
  @@index([categoriaId])
  @@map("producto")
}

model Variante {
  id             String  @id @default(uuid())
  productoId     String  @map("producto_id")
  nombre         String
  sku            String?
  precio         Decimal @db.Decimal(10, 2)
  costoCalculado Decimal @default(0) @map("costo_calculado") @db.Decimal(10, 2)

  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  receta   Receta[]
  detalles DetallePedido[]

  @@index([productoId])
  @@map("variante")
}

model ModificadorGrupo {
  id          String  @id @default(uuid())
  nombre      String
  seleccion   String  @default("unica") // unica | multiple
  min         Int     @default(0)
  max         Int?
  obligatorio Boolean @default(false)

  modificadores Modificador[]
  productos     ProductoModificadorGrupo[]

  @@map("modificador_grupo")
}

model Modificador {
  id             String  @id @default(uuid())
  grupoId        String  @map("grupo_id")
  nombre         String
  precioExtra    Decimal @default(0) @map("precio_extra") @db.Decimal(10, 2)
  insumoId       String? @map("insumo_id")
  cantidadInsumo Decimal? @map("cantidad_insumo") @db.Decimal(10, 4)

  grupo    ModificadorGrupo  @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  insumo   Insumo?           @relation(fields: [insumoId], references: [id])
  detalles DetalleModificador[]

  @@index([grupoId])
  @@map("modificador")
}

model ProductoModificadorGrupo {
  productoId String @map("producto_id")
  grupoId    String @map("grupo_id")

  producto Producto         @relation(fields: [productoId], references: [id], onDelete: Cascade)
  grupo    ModificadorGrupo @relation(fields: [grupoId], references: [id], onDelete: Cascade)

  @@id([productoId, grupoId])
  @@map("producto_modificador_grupo")
}

// ───────────────────────── Inventario y recetas ───────────────────────────

model Insumo {
  id            String   @id @default(uuid())
  nombre        String
  unidad        String // g, ml, u
  costoUnitario Decimal  @map("costo_unitario") @db.Decimal(10, 4)
  perecedero    Boolean  @default(false)
  vidaUtilDias  Int?     @map("vida_util_dias")

  receta       Receta[]
  inventario   Inventario[]
  reposiciones Reposicion[]
  mermas       Merma[]
  modificadores Modificador[]
  movStock     MovimientoStock[]

  @@map("insumo")
}

model Receta {
  id         String  @id @default(uuid())
  varianteId String  @map("variante_id")
  insumoId   String  @map("insumo_id")
  cantidad   Decimal @db.Decimal(10, 4)

  variante Variante @relation(fields: [varianteId], references: [id], onDelete: Cascade)
  insumo   Insumo   @relation(fields: [insumoId], references: [id])

  @@unique([varianteId, insumoId])
  @@map("receta")
}

model Inventario {
  id           String  @id @default(uuid())
  localId      String  @map("local_id")
  insumoId     String  @map("insumo_id")
  stockActual  Decimal @default(0) @map("stock_actual") @db.Decimal(12, 4)
  stockMinimo  Decimal @default(0) @map("stock_minimo") @db.Decimal(12, 4)
  puntoReorden Decimal @default(0) @map("punto_reorden") @db.Decimal(12, 4)

  local  Local  @relation(fields: [localId], references: [id])
  insumo Insumo @relation(fields: [insumoId], references: [id])

  @@unique([localId, insumoId])
  @@map("inventario")
}

model MovimientoStock {
  id       String   @id @default(uuid())
  localId  String   @map("local_id")
  insumoId String   @map("insumo_id")
  tipo     String // venta | reposicion | merma | ajuste | transferencia
  delta    Decimal  @db.Decimal(12, 4) // negativo descuenta
  refId    String?  @map("ref_id")
  creadoEn DateTime @default(now()) @map("creado_en")

  local  Local  @relation(fields: [localId], references: [id])
  insumo Insumo @relation(fields: [insumoId], references: [id])

  @@index([localId, insumoId])
  @@map("movimiento_stock")
}

model Proveedor {
  id           String       @id @default(uuid())
  nombre       String
  contacto     String?
  condiciones  String?
  reposiciones Reposicion[]

  @@map("proveedor")
}

model Reposicion {
  id          String   @id @default(uuid())
  localId     String   @map("local_id")
  insumoId    String   @map("insumo_id")
  proveedorId String?  @map("proveedor_id")
  cantidad    Decimal  @db.Decimal(12, 4)
  costo       Decimal  @db.Decimal(10, 2)
  fecha       DateTime @default(now())
  usuarioId   String   @map("usuario_id")

  local     Local      @relation(fields: [localId], references: [id])
  insumo    Insumo     @relation(fields: [insumoId], references: [id])
  proveedor Proveedor? @relation(fields: [proveedorId], references: [id])
  usuario   Usuario    @relation(fields: [usuarioId], references: [id])

  @@index([localId])
  @@map("reposicion")
}

model Merma {
  id        String   @id @default(uuid())
  localId   String   @map("local_id")
  insumoId  String   @map("insumo_id")
  cantidad  Decimal  @db.Decimal(12, 4)
  motivo    String
  costo     Decimal  @db.Decimal(10, 2)
  fecha     DateTime @default(now())
  usuarioId String   @map("usuario_id")

  local   Local   @relation(fields: [localId], references: [id])
  insumo  Insumo  @relation(fields: [insumoId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([localId])
  @@map("merma")
}

model AlertaStock {
  id       String   @id @default(uuid())
  localId  String   @map("local_id")
  insumoId String   @map("insumo_id")
  tipo     String
  estado   String   @default("abierta")
  creadaEn DateTime @default(now()) @map("creada_en")

  local Local @relation(fields: [localId], references: [id])

  @@index([localId])
  @@map("alerta_stock")
}

// ──────────────────────────────── Ventas ──────────────────────────────────

model Pedido {
  id          String   @id // UUID v7 generado en cliente
  operationId String   @unique @map("operation_id") // idempotencia de sync
  localId     String   @map("local_id")
  clienteId   String?  @map("cliente_id")
  usuarioId   String?  @map("usuario_id") // null = pedido por QR/pickup (sin operador)
  canal       String // mostrador | qr | pickup | delivery
  mesa        String?
  estado      String   @default("pendiente")
  subtotal    Decimal  @db.Decimal(10, 2)
  descuento   Decimal  @default(0) @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  creadoEn    DateTime @default(now()) @map("creado_en")

  local    Local           @relation(fields: [localId], references: [id])
  cliente  Cliente?        @relation(fields: [clienteId], references: [id])
  usuario  Usuario?        @relation(fields: [usuarioId], references: [id])
  detalles DetallePedido[]
  pagos    Pago[]
  consumosSuscripcion ConsumoSuscripcion[]
  movPuntos MovimientoPuntos[]

  @@index([localId, creadoEn])
  @@map("pedido")
}

model DetallePedido {
  id          String  @id @default(uuid())
  pedidoId    String  @map("pedido_id")
  varianteId  String  @map("variante_id")
  cantidad    Int
  precioUnit  Decimal @map("precio_unit") @db.Decimal(10, 2)
  subtotal    Decimal @db.Decimal(10, 2)
  notas       String?

  pedido       Pedido               @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  variante     Variante             @relation(fields: [varianteId], references: [id])
  modificadores DetalleModificador[]

  @@index([pedidoId])
  @@map("detalle_pedido")
}

model DetalleModificador {
  id              String  @id @default(uuid())
  detallePedidoId String  @map("detalle_pedido_id")
  modificadorId   String  @map("modificador_id")
  precioExtra     Decimal @map("precio_extra") @db.Decimal(10, 2)

  detalle     DetallePedido @relation(fields: [detallePedidoId], references: [id], onDelete: Cascade)
  modificador Modificador   @relation(fields: [modificadorId], references: [id])

  @@index([detallePedidoId])
  @@map("detalle_modificador")
}

model Pago {
  id         String  @id @default(uuid())
  pedidoId   String  @map("pedido_id")
  metodo     String // efectivo | tarjeta | digital
  monto      Decimal @db.Decimal(10, 2)
  propina    Decimal @default(0) @db.Decimal(10, 2)
  referencia String?
  estado     String  @default("aprobado")
  proveedor  String?

  pedido Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@index([pedidoId])
  @@map("pago")
}

// ───────────────────────── Clientes y fidelización ────────────────────────

model Cliente {
  id           String   @id @default(uuid())
  nombre       String
  telefono     String?  @unique
  email        String?  @unique
  fechaRegistro DateTime @default(now()) @map("fecha_registro")
  segmento     String?
  esVip        Boolean  @default(false) @map("es_vip")
  preferencias Json     @default("{}")

  fidelizacion  Fidelizacion?
  movPuntos     MovimientoPuntos[]
  suscripciones Suscripcion[]
  pedidos       Pedido[]

  @@map("cliente")
}

model Fidelizacion {
  id          String   @id @default(uuid())
  clienteId   String   @unique @map("cliente_id")
  puntos      Int      @default(0)
  nivel       String   @default("base")
  actualizadoEn DateTime @default(now()) @map("actualizado_en")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("fidelizacion")
}

model MovimientoPuntos {
  id        String   @id @default(uuid())
  clienteId String   @map("cliente_id")
  pedidoId  String?  @map("pedido_id")
  tipo      String // gana | canjea | ajuste
  puntos    Int
  fecha     DateTime @default(now())

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  pedido  Pedido? @relation(fields: [pedidoId], references: [id])

  @@index([clienteId])
  @@map("movimiento_puntos")
}

model Suscripcion {
  id            String   @id @default(uuid())
  clienteId     String   @map("cliente_id")
  plan          String
  estado        String   @default("activa")
  inicio        DateTime @default(now())
  fin           DateTime?
  limiteConsumos Int?    @map("limite_consumos")
  precio        Decimal  @db.Decimal(10, 2)

  cliente  Cliente              @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  consumos ConsumoSuscripcion[]

  @@index([clienteId])
  @@map("suscripcion")
}

model ConsumoSuscripcion {
  id            String   @id @default(uuid())
  suscripcionId String   @map("suscripcion_id")
  pedidoId      String   @map("pedido_id")
  fecha         DateTime @default(now())

  suscripcion Suscripcion @relation(fields: [suscripcionId], references: [id], onDelete: Cascade)
  pedido      Pedido      @relation(fields: [pedidoId], references: [id])

  @@index([suscripcionId])
  @@map("consumo_suscripcion")
}

// ─────────────────────────────── Promociones ──────────────────────────────

model Promocion {
  id            String   @id @default(uuid())
  localId       String?  @map("local_id") // null = todas las sedes
  nombre        String
  tipo          String // descuento | combo | hora_valle | nxm
  vigenciaDesde DateTime @map("vigencia_desde")
  vigenciaHasta DateTime @map("vigencia_hasta")
  prioridad     Int      @default(0)
  activa        Boolean  @default(true)

  local  Local?           @relation(fields: [localId], references: [id])
  reglas PromocionRegla[]

  @@index([localId])
  @@map("promocion")
}

model PromocionRegla {
  id          String @id @default(uuid())
  promocionId String @map("promocion_id")
  condicion   Json
  efecto      Json

  promocion Promocion @relation(fields: [promocionId], references: [id], onDelete: Cascade)

  @@index([promocionId])
  @@map("promocion_regla")
}

// ──────────────────────────── Operación de caja ───────────────────────────

model Turno {
  id        String    @id @default(uuid())
  localId   String    @map("local_id")
  usuarioId String    @map("usuario_id")
  apertura  DateTime  @default(now())
  cierre    DateTime?
  estado    String    @default("abierto")

  local      Local             @relation(fields: [localId], references: [id])
  usuario    Usuario           @relation(fields: [usuarioId], references: [id])
  movimientos MovimientoCaja[]

  @@index([localId])
  @@map("turno")
}

model Caja {
  id      String @id @default(uuid())
  localId String @map("local_id")
  nombre  String
  estado  String @default("cerrada")

  local       Local            @relation(fields: [localId], references: [id])
  movimientos MovimientoCaja[]

  @@index([localId])
  @@map("caja")
}

model MovimientoCaja {
  id      String   @id @default(uuid())
  cajaId  String   @map("caja_id")
  turnoId String   @map("turno_id")
  tipo    String // apertura | venta | retiro | cierre
  monto   Decimal  @db.Decimal(10, 2)
  fecha   DateTime @default(now())

  caja  Caja  @relation(fields: [cajaId], references: [id])
  turno Turno @relation(fields: [turnoId], references: [id])

  @@index([cajaId])
  @@index([turnoId])
  @@map("movimiento_caja")
}
