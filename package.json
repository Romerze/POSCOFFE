{
  "name": "poscoffe",
  "version": "0.0.0",
  "private": true,
  "description": "POSCOFFE — POS inteligente para cafeterías modernas",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @poscoffe/server prisma:generate",
    "db:migrate": "pnpm --filter @poscoffe/server prisma:migrate",
    "db:seed": "pnpm --filter @poscoffe/server prisma:seed",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
